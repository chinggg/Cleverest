#!/bin/bash

PROJ_NAME=libtiff
PROJ_DESC="TIFF Library and Utilities"
PROJ_REPO=https://gitlab.com/libtiff/libtiff.git
EXE=tiffcrop
DIR_REL=tools

ISSUES=(
  488  # heap-buffer-overflow /home/a13579/fuzz_lib_tiff/report/libtiff_asan/libtiff/tif_unix.c:362 in _TIFFmemset
  498  # tiffcrop: heap-buff-overflow in _TIFFmemcpy, tif_unix.c:368, different from #495
  519  # heap-buffer-overflow in extractContigSamplesBytes() at /libtiff/tools/tiffcrop.c:3215 (SIGSEGV)
  520  # heap-buffer-overflow in processCropSelections() at /libtiff/tools/tiffcrop.c:8499 (SIGSEGV)
  527  # heap-use-after-free at /libtiff/tools/tiffcrop.c:7140 in loadImage() (SIGSEGV)
  530  # SEGV at /libtiff/tif_luv.c:961 in uv_encode()
  548  # Null Pointer Dereference in tif_lzw.c.
  559  # assertion on fip->field_passcount == 1 after DNG 1.6 update
)

COMMANDS=(
  "tiffcrop -Z 1:3,2:4 -e divided @@ /dev/null"
  "tiffcrop -E right -z 1,1,2048,2048:1,2049,2048,4097 -i @@ /tmp/out.tif"
  "tiffcrop -E l -Z 12:50,12:99 -e divided -R 90 @@ /tmp/out.tif"
  "tiffcrop -Z 12:50,12:99 -R 270 @@ /dev/null" 
  "tiffcrop -z 12,50,12,99:112,150,112,199 -e divided @@ /tmp/out.tif"
  "tiffcrop -B @@ /dev/null"
  "tiffcp -i @@ /dev/null"
  "tiffinfo @@"
)

COMMITS_BIC=(
  7057734 # * libtiff/tif_dirread.c: TIFFFetchStripThing(): limit the number of items read in StripOffsets/StripByteCounts tags to the number of strips to avoid excessive memory allocation. Fixes https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2215 Credit to OSS Fuzz
  07d79fc # tiffcrop.c: Fix issue #352 heap-buffer-overflow by correcting uint32_t underflow.
  f13cf46 # TIFFReadDirEntryArrayWithLimit(): properly read from offline tag value when we clamp the number of strips to 1.
  e319508 # tiffcrop: Fix issue #330 and some more from 320 to 349
  07d79fc # tiffcrop.c: Fix issue #352 heap-buffer-overflow by correcting uint32_t underflow.
  f13cf46 # TIFFReadDirEntryArrayWithLimit(): properly read from offline tag value when we clamp the number of strips to 1.
  3079627 # LZWDecode(): major speed improvements
  b90b20d # Add DNG tags up to version 1.6.0.0 and some TIFF/EP tags and update documentation
)

COMMITS_FIX=(
  97d6585 # tiffcrop: Correct simple copy paste error. Fix #488.
  82a7fbb # tiffcrop: added check for assumption on composite images (fixes #496)
  69818e2 # tiffcrop: Amend rotateImage() not to toggle the input (main) image width and length parameters when only cropped image sections are rotated. Remove buffptr from region structure because never used.
  6366e8f # Merge branch 'tiffcrop_correctly_update_buffersize_after_rotate_fix#520' into 'master'
  ec8ef90 # tiffcrop: Do not reuse input buffer for subsequent images. Fix issue 527
  b0e1c25 # tif_luv: Check and correct for NaN data in uv_encode().
  9be22b6 # LZWDecode(): avoid crash when trying to read again from a strip whith a missing end-of-information marker (fixes #548)
  e8874d7 # Fix #559 DNG 1.6 passcount assertion
)

COMMITS=(${COMMITS_BIC[@]})
if [ "$SCENARIO" == "FIX" ]; then
    COMMITS=(${COMMITS_FIX[@]})
fi

declare -A COMMANDS_MAP IID2BIC IID2FIX COMMIT2IID
for i in "${!COMMITS[@]}"; do
  COMMANDS_MAP[${COMMITS_BIC[$i]}]="${COMMANDS[$i]}"
  COMMANDS_MAP[${COMMITS_FIX[$i]}]="${COMMANDS[$i]}"
  COMMANDS_MAP[${ISSUES[$i]}]="${COMMANDS[$i]}"
  IID2BIC[${ISSUES[$i]}]=${COMMITS_BIC[$i]}
  IID2FIX[${ISSUES[$i]}]=${COMMITS_FIX[$i]}
  COMMIT2IID[${COMMITS_BIC[$i]}]=${ISSUES[$i]}
  COMMIT2IID[${COMMITS_FIX[$i]}]=${ISSUES[$i]}
done

clone_repo() {
  git clone $PROJ_REPO
  git config --global --add safe.directory $PWD/$PROJ_NAME
}

pre_build() {
  local builddir=$1
  git restore .
}

post_build() {
  local builddir=$1

  # Check for the existence of the tools
  if [ ! -f $builddir/$DIR_REL/tiffcrop ] || [ ! -f $builddir/$DIR_REL/tiffcp ] || [ ! -f $builddir/$DIR_REL/tiffinfo ]; then
    echo "ERROR: One or more tools did not build"
    exit 1
  fi
  
  # Check for AFL or gcov instrumentation
  if [[ $builddir == buildafl* ]]; then
    for tool in tiffcrop tiffcp tiffinfo; do
      if [ -z "$(nm -an $builddir/$DIR_REL/$tool | grep __afl)" ]; then
        echo "ERROR: $builddir/$DIR_REL/$tool does not have afl symbols"
        exit 1
      fi
    done
  else
    if [ -z "$(find $builddir -name '*.gcno')" ]; then
      echo "ERROR: $builddir does not have .gcno files"
      exit 1
    fi
  fi

  git restore .
}

# PWD is root of project repo for funcs below
build_target() {
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-build_$commit}
  
  export CFLAGS_ASAN="-fsanitize=address -fno-omit-frame-pointer"
  export LDFLAGS_ASAN="-fsanitize=address -fno-omit-frame-pointer"
  export CFLAGS_GCOV="-fprofile-arcs -ftest-coverage -DFUZZING_BUILD_MODE_UNSAFE_FOR_PRODUCTION"
  export LDFLAGS_GCOV="--coverage"
  export CFLAGS="$CFLAGS_GCOV"
  export LDFLAGS="$LDFLAGS_GCOV"
  
  cmake -G Ninja -S . -B $builddir -DCMAKE_C_FLAGS="$CFLAGS" -DCMAKE_CXX_FLAGS="$CFLAGS"
  ninja -C $builddir -j16
  unset CFLAGS LDFLAGS
}

buildafl_target() {
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-buildafl_$commit}
  
  export CC="afl-clang-fast"
  export CXX="afl-clang-fast++"
  export AFL_USE_ASAN=1
  
  cmake -G Ninja -S . -B $builddir
  ninja -C $builddir -j16
  unset CC CXX AFL_USE_ASAN
}

buildwaflgo_target() {( set -e
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-buildwaflgo_$commit}
  
  export ADD="-g --notI "
  export CC=/home/WAFLGo/afl-clang-fast CXX=/home/WAFLGo/afl-clang-fast++  CFLAGS="$ADD" CXXFLAGS="$ADD"
  export AFL_CC=gclang AFL_CXX=gclang++
  
  # Build before bugfix commit if this is a fix commit
  if [[ " ${COMMITS_FIX[@]} " =~ " ${commit} " ]]; then
    git checkout $commit^
  fi
  
  ./configure --prefix=$builddir
  make -j32
  make install
  
  unset AFL_CC AFL_CXX
  git checkout $commit  # checkout back to commit so commit.diff is correct

  # Get target executable based on issue number
  local issue_num=${COMMIT2IID[$commit]}
  local target_exe=""
  
  if [[ $issue_num -le 530 ]]; then
    target_exe="tiffcrop"
  elif [[ $issue_num -eq 548 ]]; then
    target_exe="tiffcp"
  elif [[ $issue_num -eq 559 ]]; then
    target_exe="tiffinfo"
  fi

  # Get bitcode file from executable file
  pushd $builddir/$DIR_REL
  get-bc $target_exe  # will generate $target_exe.bc

  # Set the target site
  echo $'' > $TMP_DIR/BBtargets.txt
  git diff HEAD^1 HEAD > ./commit.diff
  cp /home/showlinenum.awk .
  sed -i -e 's/\r$//' showlinenum.awk
  chmod +x showlinenum.awk
  cat ./commit.diff |  ./showlinenum.awk show_header=0 path=1 | grep -e "\.[ch]:[0-9]*:+" -e "\.cpp:[0-9]*:+" -e "\.cc:[0-9]*:+" | cut -d+ -f1 | rev | cut -c2- | rev > ./targets

  # Instrument
  /home/WAFLGo/instrument/bin/cbi --targets=targets $target_exe.bc --stats=false
  cp ./targets_id.txt /home
  cp ./suffix.txt /home
  cp ./targets*.txt /home
  cp ./distance.txt /home
  cp ./branch-distance.txt /home
  cp ./branch-distance-min.txt /home
  cp ./branch-curloc.txt /home
  cp ./*_data.txt /home

  # Compile bitcode file to executable file
  /home/WAFLGo/afl-clang-fast++ $target_exe.ci.bc -o $target_exe.ci
  cp ./bbinfo-fast.txt /home/bbinfo-ci-bc.txt
  cp ./branch-distance-order.txt /home
  cp ./*-distance-order.txt /home
  cp ./*-order.txt /home
  
  popd
)}

post_buildwaflgo() {
  local builddir=$1
  local issue_num=$(echo $builddir | grep -o '[0-9]\+')
  local target_exe=""
  
  if [[ $issue_num -le 530 ]]; then
    target_exe="tiffcrop"
  elif [[ $issue_num -eq 548 ]]; then
    target_exe="tiffcp"
  elif [[ $issue_num -eq 559 ]]; then
    target_exe="tiffinfo"
  fi

  # assert *.bc and *.ci files exist in $builddir
  if [ ! -f $builddir/$DIR_REL/$target_exe.bc ]; then
    echo "ERROR: $builddir/$DIR_REL/$target_exe.bc did not build"
    exit 1
  fi
  if [ ! -f $builddir/$DIR_REL/$target_exe.ci ]; then
    echo "ERROR: $builddir/$DIR_REL/$target_exe.ci did not build"
    exit 1
  fi

  git restore .
}

run_waflgo() {(set -x;
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1-buildwaflgo_$commit}
  local seedsdir=${2-/home/seeds/general_evaluation/libtiff}
  local issue_num=${COMMIT2IID[$commit]}
  local target_exe=""
  
  if [[ $issue_num -le 530 ]]; then
    target_exe="tiffcrop"
  elif [[ $issue_num -eq 548 ]]; then
    target_exe="tiffcp"
  elif [[ $issue_num -eq 559 ]]; then
    target_exe="tiffinfo"
  fi
  
  /home/WAFLGo/afl-fuzz -T waflgo-$PROJ_NAME -t 1000+ -m none -z exp -c 45m -q 1 -i $seedsdir -o /home/out -- /home/libtiff/$builddir/$DIR_REL/$target_exe.ci @@
)}

gen_cov() {
  # pre-condition: CWD is repo root, may checkout to commit^ or commit
  local builddir=$1
  local commit=$(echo $builddir | sed -n 's/.*_\(.*\)/\1/p')
  local changed_files=${2-"$(git diff --name-only $commit^ $commit)"}
  local cnt=$3
  gcda_files=$(find $builddir -name "*.gcda")
  for gcda in $gcda_files; do
      gcov -r -H -o $gcda $changed_files
  done
  for file in $changed_files; do
      filename=$(basename $file)
      # find gcda object file in $builddir_before by each file name
      gcda=$(find $builddir -name $filename.gcda)
      if [[ "$gcda" ]]; then
          gcov -H -o $gcda $file
      else
          echo "No $filename.gcda found for $file in $builddir."
      fi
      # if $builddir contain "before", mv gcov file to $filename.gcov.before_$commit.$cnt
      # otherwise, mv gcov file to $filename.gcov.after_$commit.$cnt
      if [[ $builddir == *before* ]]; then
          mv $filename.gcov $filename.gcov.before_$commit.$cnt
      else
          mv $filename.gcov $filename.gcov.after_$commit.$cnt
      fi
  done
  rm *.gcov
}

check_cov() {
  # check overlap of commit affected lines and covered lines
  # pre-condition: CWD is repo root, where .gcov files are generated
  local commit=${1-"$(git rev-parse --short=7 HEAD)"}
  local changed_file=${2-"$(git diff --name-only HEAD^ HEAD)"}
  local cnt=$3
  cover_before=""
  cover_after=""
  for file in $changed_files; do
      filename=$(basename $file)
      gcov_before=$filename.gcov.before_$commit.$cnt
      gcov_after=$filename.gcov.after_$commit.$cnt
      if [ ! -f $gcov_before ] || [ ! -f $gcov_after ]; then
          echo "No gcov report found for $file before/after commit $commit, skipping." | tee -a $chat_log
          continue
      else
          echo "Checking covered lines in $gcov_before and $gcov_after." | tee -a $chat_log
      fi
      changed_lines=$(commit_affected_lines "$commit" "$file")
      lines_before=$(echo "$changed_lines" | sed -n 's/^lines_before://p')
      lines_after=$(echo "$changed_lines" | sed -n 's/^lines_after://p')
      echo "commit $commit^ affected lines in $file: $lines_before" | tee -a $chat_log
      echo "commit $commit affected lines in $file: $lines_after" | tee -a $chat_log
      cover_lines_before=()
      for line in ${lines_before//,/ }; do
          # determine if line is coveraged in pre-commit gcov report
          covered_lines=$(cat $gcov_before | grep -v '^\s*-' | grep -v '^\s*#####')
          pat="^[[:blank:]]*.*:[[:blank:]]*$line:.*$"  # before second colon in each line
          if [[ $covered_lines =~ $pat ]]; then
              cover_lines_before+=($line)
          fi
      done
      if [ ${#cover_lines_before[@]} -gt 0 ]; then
          cover_before+="$filename:${cover_lines_before[@]}\n"
      fi
      cover_lines_after=()
      for line in ${lines_after//,/ }; do
          # determine if line is coveraged in post-commit gcov report
          covered_lines=$(cat $gcov_after | grep -v '^\s*-' | grep -v '^\s*#####')
          pat="^[[:blank:]]*.*:[[:blank:]]*$line:.*$"  # before second colon in each line
          if [[ $covered_lines =~ $pat ]]; then
              cover_lines_after+=($line)
          fi
      done
      if [ ${#cover_lines_after[@]} -gt 0 ]; then
          cover_after+="$filename:${cover_lines_after[@]}\n"
      fi
  done
  # return true if $cover_before or $cover_after is not empty
  if [ -n "$cover_before" ] || [ -n "$cover_after" ]; then
      echo "Covered lines before commit $commit: $cover_before"
      echo "Covered lines after commit $commit: $cover_after"
      return $(true)
  else
      return $(false)
  fi
}
